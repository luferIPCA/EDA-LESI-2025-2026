    "version": "0.2.0",
    "configurations": [
        {
            "name": "(gdb) Debug Calculus",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}\\Calculus.exe",
            "args": [],
            "stopAtEntry": true,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": true,
            "MIMode": "gdb",
            "miDebuggerPath": "C:\\MinGW\\bin\\gdb.exe",
            "preLaunchTask": "build-make",
            "setupCommands": [
                {
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        }
    ]
}